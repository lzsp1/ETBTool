<Window x:Class="ETBTool.Windows.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True" WindowStyle="None" ShowInTaskbar="False"
        ResizeMode="NoResize" Background="Transparent"
        SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner">
	<!-- ★ 圆角背景遮罩 -->
	<Border x:Name="Overlay" Background="#90000000" CornerRadius="12">
		<Grid VerticalAlignment="Center" HorizontalAlignment="Center">
			<Border x:Name="DialogCard" CornerRadius="16" Padding="32" Width="420"
                    Background="{DynamicResource WindowBackground}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
				<Border.Effect>
					<DropShadowEffect BlurRadius="48" ShadowDepth="4" Opacity="0.6" Color="#000"/>
				</Border.Effect>
				<StackPanel>
					<TextBlock x:Name="TitleBlock" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>
					<TextBlock x:Name="MessageBlock" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimary}" FontSize="14"
                               LineHeight="24" Margin="0,0,0,28"/>
					<StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right"/>
				</StackPanel>
			</Border>
		</Grid>
	</Border>
</Window>