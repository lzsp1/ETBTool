<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<SolidColorBrush x:Key="AccentColor"      Color="#00F5D4"/>
	<SolidColorBrush x:Key="AccentHoverColor" Color="#5CFFE0"/>
	<SolidColorBrush x:Key="DangerColor"      Color="#FF006E"/>
	<SolidColorBrush x:Key="SuccessColor"     Color="#00FF88"/>
	<SolidColorBrush x:Key="WarningColor"     Color="#FFBE0B"/>
	<Color x:Key="HoverTintColor">#00F5D410</Color>

	<SolidColorBrush x:Key="DarkBackground"     Color="#0A0A0A"/>
	<SolidColorBrush x:Key="DarkSurface"        Color="#141414"/>
	<SolidColorBrush x:Key="DarkTextPrimary"    Color="#FFFFFF"/>
	<SolidColorBrush x:Key="DarkTextSecondary"  Color="#909090"/>
	<SolidColorBrush x:Key="DarkBorder"         Color="#00000000"/>
	<SolidColorBrush x:Key="DarkButtonBg"       Color="#1E1E1E"/>
	<SolidColorBrush x:Key="DarkButtonHover"    Color="#282828"/>
	<SolidColorBrush x:Key="DarkCardBg"         Color="#181818"/>
	<SolidColorBrush x:Key="DarkCardHover"      Color="#1F1F1F"/>
	<SolidColorBrush x:Key="DarkSidebar"        Color="#0E0E0E"/>

	<SolidColorBrush x:Key="LightBackground"    Color="#1A1A2E"/>
	<SolidColorBrush x:Key="LightSurface"       Color="#22223A"/>
	<SolidColorBrush x:Key="LightTextPrimary"   Color="#FFFFFF"/>
	<SolidColorBrush x:Key="LightTextSecondary" Color="#A0A0C0"/>
	<SolidColorBrush x:Key="LightBorder"        Color="#00000000"/>
	<SolidColorBrush x:Key="LightButtonBg"      Color="#2A2A45"/>
	<SolidColorBrush x:Key="LightButtonHover"   Color="#35355A"/>
	<SolidColorBrush x:Key="LightCardBg"        Color="#1E1E35"/>
	<SolidColorBrush x:Key="LightCardHover"     Color="#262645"/>
	<SolidColorBrush x:Key="LightSidebar"       Color="#151528"/>

	<SolidColorBrush x:Key="WindowBackground"       Color="#0A0A0A"/>
	<SolidColorBrush x:Key="SurfaceColor"           Color="#141414"/>
	<SolidColorBrush x:Key="TextPrimary"            Color="#FFFFFF"/>
	<SolidColorBrush x:Key="TextSecondary"          Color="#909090"/>
	<!-- ★ 外圈边框设为透明 -->
	<SolidColorBrush x:Key="BorderColor"            Color="#00000000"/>
	<SolidColorBrush x:Key="ButtonBackground"       Color="#1E1E1E"/>
	<SolidColorBrush x:Key="ButtonHoverBackground"  Color="#282828"/>
	<SolidColorBrush x:Key="CardBackground"         Color="#181818"/>
	<SolidColorBrush x:Key="CardHoverBackground"    Color="#1F1F1F"/>
	<SolidColorBrush x:Key="SidebarBackground"      Color="#0E0E0E"/>
</ResourceDictionary>