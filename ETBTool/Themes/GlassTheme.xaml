<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<SolidColorBrush x:Key="AccentColor"        Color="#6C5CE7"/>
	<SolidColorBrush x:Key="AccentHoverColor"   Color="#7F70F0"/>
	<SolidColorBrush x:Key="DangerColor"        Color="#E74C3C"/>
	<SolidColorBrush x:Key="SuccessColor"       Color="#2ECC71"/>
	<SolidColorBrush x:Key="WarningColor"       Color="#F39C12"/>
	<Color x:Key="HoverTintColor">#FFFFFF0A</Color>

	<!-- 深色：降低亮度、提高文字对比 -->
	<SolidColorBrush x:Key="DarkBackground"     Color="#08081A"/>
	<SolidColorBrush x:Key="DarkSurface"        Color="#10102A"/>
	<SolidColorBrush x:Key="DarkTextPrimary"    Color="#EEEEF5"/>
	<SolidColorBrush x:Key="DarkTextSecondary"  Color="#8888A8"/>
	<SolidColorBrush x:Key="DarkBorder"         Color="#FFFFFF12"/>
	<SolidColorBrush x:Key="DarkButtonBg"       Color="#1A1A38"/>
	<SolidColorBrush x:Key="DarkButtonHover"    Color="#252550"/>
	<SolidColorBrush x:Key="DarkCardBg"         Color="#0E0E25"/>
	<SolidColorBrush x:Key="DarkCardHover"      Color="#151535"/>
	<SolidColorBrush x:Key="DarkSidebar"        Color="#060615"/>

	<!-- 浅色 -->
	<SolidColorBrush x:Key="LightBackground"    Color="#F0F2F8"/>
	<SolidColorBrush x:Key="LightSurface"       Color="#FFFFFF"/>
	<SolidColorBrush x:Key="LightTextPrimary"   Color="#1A1A2E"/>
	<SolidColorBrush x:Key="LightTextSecondary" Color="#666688"/>
	<SolidColorBrush x:Key="LightBorder"        Color="#00000012"/>
	<SolidColorBrush x:Key="LightButtonBg"      Color="#E8EAF0"/>
	<SolidColorBrush x:Key="LightButtonHover"   Color="#DDDFE8"/>
	<SolidColorBrush x:Key="LightCardBg"        Color="#FFFFFFCC"/>
	<SolidColorBrush x:Key="LightCardHover"     Color="#FFFFFFDD"/>
	<SolidColorBrush x:Key="LightSidebar"       Color="#E4E6EE"/>

	<SolidColorBrush x:Key="WindowBackground"       Color="#08081A"/>
	<SolidColorBrush x:Key="SurfaceColor"           Color="#10102A"/>
	<SolidColorBrush x:Key="TextPrimary"            Color="#EEEEF5"/>
	<SolidColorBrush x:Key="TextSecondary"          Color="#8888A8"/>
	<SolidColorBrush x:Key="BorderColor"            Color="#FFFFFF12"/>
	<SolidColorBrush x:Key="ButtonBackground"       Color="#1A1A38"/>
	<SolidColorBrush x:Key="ButtonHoverBackground"  Color="#252550"/>
	<SolidColorBrush x:Key="CardBackground"         Color="#0E0E25"/>
	<SolidColorBrush x:Key="CardHoverBackground"    Color="#151535"/>
	<SolidColorBrush x:Key="SidebarBackground"      Color="#060615"/>
</ResourceDictionary>