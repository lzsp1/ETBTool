<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<SolidColorBrush x:Key="AccentColor"      Color="#FF6B6B"/>
	<SolidColorBrush x:Key="AccentHoverColor" Color="#FF8A8A"/>
	<SolidColorBrush x:Key="DangerColor"      Color="#EE5A24"/>
	<SolidColorBrush x:Key="SuccessColor"     Color="#6AB04C"/>
	<SolidColorBrush x:Key="WarningColor"     Color="#F9CA24"/>
	<Color x:Key="HoverTintColor">#FFFFFF08</Color>

	<SolidColorBrush x:Key="DarkBackground"     Color="#111120"/>
	<SolidColorBrush x:Key="DarkSurface"        Color="#1A1A30"/>
	<SolidColorBrush x:Key="DarkTextPrimary"    Color="#E0E0FF"/>
	<SolidColorBrush x:Key="DarkTextSecondary"  Color="#7070A0"/>
	<SolidColorBrush x:Key="DarkBorder"         Color="#FFFFFF10"/>
	<SolidColorBrush x:Key="DarkButtonBg"       Color="#252545"/>
	<SolidColorBrush x:Key="DarkButtonHover"    Color="#30305A"/>
	<SolidColorBrush x:Key="DarkCardBg"         Color="#161630"/>
	<SolidColorBrush x:Key="DarkCardHover"      Color="#1E1E40"/>
	<SolidColorBrush x:Key="DarkSidebar"        Color="#0C0C18"/>

	<SolidColorBrush x:Key="LightBackground"    Color="#F5F5FF"/>
	<SolidColorBrush x:Key="LightSurface"       Color="#FFFFFF"/>
	<SolidColorBrush x:Key="LightTextPrimary"   Color="#141428"/>
	<SolidColorBrush x:Key="LightTextSecondary" Color="#6060A0"/>
	<SolidColorBrush x:Key="LightBorder"        Color="#00000010"/>
	<SolidColorBrush x:Key="LightButtonBg"      Color="#EEEEFF"/>
	<SolidColorBrush x:Key="LightButtonHover"   Color="#E0E0F5"/>
	<SolidColorBrush x:Key="LightCardBg"        Color="#FFFFFF"/>
	<SolidColorBrush x:Key="LightCardHover"     Color="#F8F8FF"/>
	<SolidColorBrush x:Key="LightSidebar"       Color="#EAEAFF"/>

	<SolidColorBrush x:Key="WindowBackground"       Color="#111120"/>
	<SolidColorBrush x:Key="SurfaceColor"           Color="#1A1A30"/>
	<SolidColorBrush x:Key="TextPrimary"            Color="#E0E0FF"/>
	<SolidColorBrush x:Key="TextSecondary"          Color="#7070A0"/>
	<SolidColorBrush x:Key="BorderColor"            Color="#FFFFFF10"/>
	<SolidColorBrush x:Key="ButtonBackground"       Color="#252545"/>
	<SolidColorBrush x:Key="ButtonHoverBackground"  Color="#30305A"/>
	<SolidColorBrush x:Key="CardBackground"         Color="#161630"/>
	<SolidColorBrush x:Key="CardHoverBackground"    Color="#1E1E40"/>
	<SolidColorBrush x:Key="SidebarBackground"      Color="#0C0C18"/>
</ResourceDictionary>