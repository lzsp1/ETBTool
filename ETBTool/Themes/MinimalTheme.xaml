<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<SolidColorBrush x:Key="AccentColor"      Color="#111111"/>
	<SolidColorBrush x:Key="AccentHoverColor" Color="#333333"/>
	<SolidColorBrush x:Key="DangerColor"      Color="#DC3545"/>
	<SolidColorBrush x:Key="SuccessColor"     Color="#28A745"/>
	<SolidColorBrush x:Key="WarningColor"     Color="#FFC107"/>
	<Color x:Key="HoverTintColor">#00000006</Color>

	<!-- ★ 深色模式 -->
	<SolidColorBrush x:Key="DarkBackground"     Color="#181818"/>
	<SolidColorBrush x:Key="DarkSurface"        Color="#222222"/>
	<SolidColorBrush x:Key="DarkTextPrimary"    Color="#E8E8E8"/>
	<SolidColorBrush x:Key="DarkTextSecondary"  Color="#888888"/>
	<SolidColorBrush x:Key="DarkBorder"         Color="#333333"/>
	<SolidColorBrush x:Key="DarkButtonBg"       Color="#2A2A2A"/>
	<SolidColorBrush x:Key="DarkButtonHover"    Color="#353535"/>
	<SolidColorBrush x:Key="DarkCardBg"         Color="#1E1E1E"/>
	<SolidColorBrush x:Key="DarkCardHover"      Color="#282828"/>
	<SolidColorBrush x:Key="DarkSidebar"        Color="#141414"/>

	<!-- 浅色模式 -->
	<SolidColorBrush x:Key="LightBackground"    Color="#FFFFFF"/>
	<SolidColorBrush x:Key="LightSurface"       Color="#FAFAFA"/>
	<SolidColorBrush x:Key="LightTextPrimary"   Color="#111111"/>
	<SolidColorBrush x:Key="LightTextSecondary" Color="#888888"/>
	<SolidColorBrush x:Key="LightBorder"        Color="#E5E5E5"/>
	<SolidColorBrush x:Key="LightButtonBg"      Color="#F5F5F5"/>
	<SolidColorBrush x:Key="LightButtonHover"   Color="#EBEBEB"/>
	<SolidColorBrush x:Key="LightCardBg"        Color="#FAFAFA"/>
	<SolidColorBrush x:Key="LightCardHover"     Color="#F0F0F0"/>
	<SolidColorBrush x:Key="LightSidebar"       Color="#FFFFFF"/>

	<SolidColorBrush x:Key="WindowBackground"       Color="#181818"/>
	<SolidColorBrush x:Key="SurfaceColor"           Color="#222222"/>
	<SolidColorBrush x:Key="TextPrimary"            Color="#E8E8E8"/>
	<SolidColorBrush x:Key="TextSecondary"          Color="#888888"/>
	<SolidColorBrush x:Key="BorderColor"            Color="#333333"/>
	<SolidColorBrush x:Key="ButtonBackground"       Color="#2A2A2A"/>
	<SolidColorBrush x:Key="ButtonHoverBackground"  Color="#353535"/>
	<SolidColorBrush x:Key="CardBackground"         Color="#1E1E1E"/>
	<SolidColorBrush x:Key="CardHoverBackground"    Color="#282828"/>
	<SolidColorBrush x:Key="SidebarBackground"      Color="#141414"/>
</ResourceDictionary>