<Page x:Class="ETBTool.Views.CrashLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:etb="clr-namespace:ETBTool.Utils"
      Background="Transparent"
      etb:ScrollBubble.Enabled="True">
	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
		<StackPanel>
			<TextBlock Style="{StaticResource PageTitle}" Text="崩溃日志"/>
			<TextBlock Style="{StaticResource MutedText}"
                       Text="查看和管理崩溃日志（支持 Ctrl+点击多选）" Margin="0,-4,0,20"/>

			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock Style="{StaticResource SectionTitle}" Text="日志路径"/>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox x:Name="LogPathBox" IsReadOnly="True" Margin="0,0,8,0"/>
						<Button Grid.Column="1" Content="打开" Style="{StaticResource BaseButton}"
                                Click="OpenFolder_Click" Margin="0,0,8,0"/>
						<Button Grid.Column="2" Content="复制" Style="{StaticResource BaseButton}"
                                Click="CopyPath_Click"/>
					</Grid>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock Style="{StaticResource SectionTitle}" Text="日志文件列表"/>

					<Grid Margin="0,0,0,4">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="120"/>
							<ColumnDefinition Width="160"/>
						</Grid.ColumnDefinitions>
						<TextBlock Text="文件名" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
						<TextBlock Grid.Column="1" Text="大小" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
						<TextBlock Grid.Column="2" Text="修改时间" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
					</Grid>
					<Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,4"/>

					<!-- ★ 多选 -->
					<ListBox x:Name="FileListBox" Height="300" Margin="0,0,0,12"
                             SelectionMode="Extended"
                             ItemContainerStyle="{StaticResource TableListBoxItem}">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="120"/>
										<ColumnDefinition Width="160"/>
									</Grid.ColumnDefinitions>
									<TextBlock Text="{Binding Name}" Style="{StaticResource ListPrimaryText}"/>
									<TextBlock Grid.Column="1" Text="{Binding Size}" Style="{StaticResource ListSecondaryText}"/>
									<TextBlock Grid.Column="2" Text="{Binding Modified}" Style="{StaticResource ListSecondaryText}"/>
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>

					<WrapPanel>
						<Button Content="刷新"    Style="{StaticResource AccentButton}"
                                Click="Refresh_Click" Margin="0,0,8,0"/>
						<Button Content="打开选中" Style="{StaticResource BaseButton}"
                                Click="Open_Click" Margin="0,0,8,0"/>
						<Button Content="删除选中" Style="{StaticResource DangerButton}"
                                Click="Delete_Click" Margin="0,0,8,0"/>
						<Button Content="清空全部" Style="{StaticResource DangerButton}"
                                Click="ClearAll_Click"/>
					</WrapPanel>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</Page>