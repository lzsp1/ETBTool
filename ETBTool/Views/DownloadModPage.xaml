<Page x:Class="ETBTool.Views.DownloadModPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:etb="clr-namespace:ETBTool.Utils"
      Background="Transparent" etb:ScrollBubble.Enabled="True">
	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,12">
		<StackPanel MaxWidth="520" HorizontalAlignment="Center">
			<TextBlock x:Name="PageTitle" Style="{StaticResource PageTitle}"/>
			<TextBlock x:Name="PageSub" Style="{StaticResource MutedText}" Margin="0,-4,0,12"/>
			<Button x:Name="BtnGo" Style="{StaticResource AccentButton}"
                    Click="Go_Click" HorizontalAlignment="Left" Width="140"/>
		</StackPanel>
	</ScrollViewer>
</Page>