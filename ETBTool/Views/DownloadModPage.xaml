<Page x:Class="ETBTool.Views.DownloadModPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520" Margin="0,60">
        <Border Style="{StaticResource Card}" Padding="36">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="  下载 Mod" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                <TextBlock TextWrapping="Wrap" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" FontSize="14" LineHeight="26"
                           Text="我们已终止与逃离后室模组库的合作，正在寻找新的合作商。如果您拥有该模组库的账号，请点击下方按钮跳转到官方渠道"/>
                <Button Content="前往官方渠道" Style="{StaticResource AccentButton}"
                        Click="Go_Click" Margin="0,28,0,0" Padding="28,14" FontSize="15"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>