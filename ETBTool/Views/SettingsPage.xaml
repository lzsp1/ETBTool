<Page x:Class="ETBTool.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:etb="clr-namespace:ETBTool.Utils"
      Background="Transparent"
      etb:ScrollBubble.Enabled="True">
	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
		<StackPanel>
			<TextBlock Style="{StaticResource PageTitle}" Text="  设置"/>
			<TextBlock Style="{StaticResource MutedText}" Text="主题、颜色、路径配置"
                       Margin="0,-4,0,20"/>

			<!-- 主题风格 -->
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock Style="{StaticResource SectionTitle}" Text="  界面风格"/>
					<ListBox x:Name="StyleList" Height="200" SelectionChanged="Style_Changed"/>
				</StackPanel>
			</Border>

			<!-- 颜色模式 -->
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock Style="{StaticResource SectionTitle}" Text="  颜色模式"/>
					<ListBox x:Name="ModeList" Height="110" SelectionChanged="Mode_Changed"/>
				</StackPanel>
			</Border>

			<!-- 自定义强调色 -->
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock Style="{StaticResource SectionTitle}" Text="  自定义强调色"/>
					<TextBlock Style="{StaticResource MutedText}" Text="点击色块更换主题强调色"
                               Margin="0,-8,0,12"/>
					<WrapPanel x:Name="ColorSwatches" Margin="0,0,0,12"/>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock Text="自定义 HEX:" VerticalAlignment="Center"
                                   Margin="0,0,8,0" Foreground="{DynamicResource TextPrimary}"/>
						<TextBox x:Name="HexInput" Grid.Column="1" Margin="0,0,8,0"
                                 ToolTip="输入颜色值，如 #FF6B6B"/>
						<Button Grid.Column="2" Content="应用" Style="{StaticResource AccentButton}"
                                Click="ApplyHex" Margin="0,0,8,0"/>
						<Button Grid.Column="3" Content="重置" Style="{StaticResource BaseButton}"
                                Click="ResetAccent"/>
					</Grid>
				</StackPanel>
			</Border>

			<!-- 背景图片 -->
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock Style="{StaticResource SectionTitle}" Text="  背景图片"/>
					<TextBlock Style="{StaticResource MutedText}"
                               Text="上传图片作为背景（菜单栏和内容区通铺）"
                               Margin="0,-8,0,12"/>
					<WrapPanel>
						<Button Content="选择图片" Style="{StaticResource BaseButton}"
                                Click="BrowseBg" Margin="0,0,8,0"/>
						<Button Content="清除背景" Style="{StaticResource BaseButton}"
                                Click="ClearBg"/>
					</WrapPanel>
					<TextBlock x:Name="BgPathText" Style="{StaticResource MutedText}"
                               Margin="0,8,0,0"/>
				</StackPanel>
			</Border>

			<!-- 自定义路径 -->
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock Style="{StaticResource SectionTitle}"
                               Text="  自定义路径（留空自动检测）"/>

					<TextBlock Text="存档路径" Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,4"/>
					<Grid Margin="0,0,0,12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox x:Name="SavePathBox" Margin="0,0,8,0"/>
						<Button Grid.Column="1" Content="浏览"
                                Style="{StaticResource BaseButton}"
                                Click="BrowseSave" Margin="0,0,4,0"/>
						<Button Grid.Column="2" Content="重置"
                                Style="{StaticResource BaseButton}"
                                Click="ResetSavePath"/>
					</Grid>

					<TextBlock Text="崩溃日志路径"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
					<Grid Margin="0,0,0,12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox x:Name="CrashPathBox" Margin="0,0,8,0"/>
						<Button Grid.Column="1" Content="浏览"
                                Style="{StaticResource BaseButton}"
                                Click="BrowseCrash" Margin="0,0,4,0"/>
						<Button Grid.Column="2" Content="重置"
                                Style="{StaticResource BaseButton}"
                                Click="ResetCrashPath"/>
					</Grid>

					<TextBlock Text="游戏安装路径"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
					<Grid Margin="0,0,0,12">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox x:Name="GamePathBox" Margin="0,0,8,0"/>
						<Button Grid.Column="1" Content="浏览"
                                Style="{StaticResource BaseButton}"
                                Click="BrowseGame" Margin="0,0,4,0"/>
						<Button Grid.Column="2" Content="重置"
                                Style="{StaticResource BaseButton}"
                                Click="ResetGamePath"/>
					</Grid>

					<Button Content="  保存路径设置" Style="{StaticResource AccentButton}"
                            Click="SavePaths" HorizontalAlignment="Left"/>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</Page>