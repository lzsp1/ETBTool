<Page x:Class="ETBTool.Views.LogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
	<Grid Margin="28,24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<StackPanel>
			<TextBlock Style="{StaticResource PageTitle}" Text="  操作日志"/>
			<TextBlock Style="{StaticResource MutedText}" Text="记录软件所有操作后台内容" Margin="0,-4,0,20"/>
		</StackPanel>

		<TextBox x:Name="LogTextBox" Grid.Row="1" IsReadOnly="True"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12" Margin="0,0,0,12"/>

		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Content="刷新" Style="{StaticResource BaseButton}"
                    Click="Refresh_Click" Margin="0,0,8,0"/>
			<Button Content="清空日志" Style="{StaticResource DangerButton}"
                    Click="Clear_Click"/>
		</StackPanel>
	</Grid>
</Page>