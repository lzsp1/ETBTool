<Page x:Class="ETBTool.Views.LogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:etb="clr-namespace:ETBTool.Utils" Background="Transparent" etb:ScrollBubble.Enabled="True">
	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
		<StackPanel>
			<TextBlock x:Name="PageTitle" Style="{StaticResource PageTitle}"/>
			<TextBlock x:Name="PageSub" Style="{StaticResource MutedText}" Margin="0,-4,0,20"/>
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBox x:Name="LogTextBox" Height="420" IsReadOnly="True"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"/>
					<WrapPanel Margin="0,12,0,0">
						<Button x:Name="BtnRefresh" Style="{StaticResource AccentButton}" Click="Refresh_Click" Margin="0,0,8,0"/>
						<Button x:Name="BtnClear" Style="{StaticResource DangerButton}" Click="Clear_Click"/>
					</WrapPanel>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</Page>