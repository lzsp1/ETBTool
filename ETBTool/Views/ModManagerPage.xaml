<Page x:Class="ETBTool.Views.ModManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:etb="clr-namespace:ETBTool.Utils" Background="Transparent" etb:ScrollBubble.Enabled="True">
	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
		<StackPanel>
			<TextBlock x:Name="PageTitle" Style="{StaticResource PageTitle}"/>
			<TextBlock x:Name="PageSub" Style="{StaticResource MutedText}" Margin="0,-4,0,20"/>
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock x:Name="LblPath" Style="{StaticResource SectionTitle}"/>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox x:Name="ModPathBox" IsReadOnly="True" Margin="0,0,8,0"/>
						<Button x:Name="BtnOpen" Grid.Column="1" Style="{StaticResource BaseButton}" Click="OpenRoot" Margin="0,0,8,0"/>
						<Button x:Name="BtnCopy" Grid.Column="2" Style="{StaticResource BaseButton}" Click="CopyRoot"/>
					</Grid>
				</StackPanel>
			</Border>
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<StackPanel Orientation="Horizontal" Margin="0,0,0,12">
						<TextBlock x:Name="LblList" Style="{StaticResource SectionTitle}" Margin="0"/>
						<TextBlock x:Name="LoadingHint" Style="{StaticResource MutedText}" VerticalAlignment="Center" Visibility="Collapsed"/>
						<TextBlock x:Name="CurrentDirText" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="12,0,0,0"/>
					</StackPanel>
					<Grid Margin="0,0,0,4">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="60"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="160"/>
							<ColumnDefinition Width="120"/>
							<ColumnDefinition Width="160"/>
						</Grid.ColumnDefinitions>
						<TextBlock x:Name="HStatus" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
						<TextBlock x:Name="HName"   Grid.Column="1" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
						<TextBlock x:Name="HFile"   Grid.Column="2" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
						<TextBlock x:Name="HSize"   Grid.Column="3" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
						<TextBlock x:Name="HMod"    Grid.Column="4" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
					</Grid>
					<Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,4"/>
					<ListBox x:Name="ModListBox" Height="260" Margin="0,0,0,12" SelectionMode="Extended" SelectionChanged="ModSel" MouseDoubleClick="ModDblClick" ItemContainerStyle="{StaticResource TableListBoxItem}">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="60"/>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="160"/>
										<ColumnDefinition Width="120"/>
										<ColumnDefinition Width="160"/>
									</Grid.ColumnDefinitions>
									<Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Background="{Binding StatusColor}">
										<TextBlock Text="{Binding Status}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
									</Border>
									<TextBlock Grid.Column="1" Text="{Binding DisplayName}" Style="{StaticResource ListPrimaryText}"/>
									<TextBlock Grid.Column="2" Text="{Binding FileName}" Style="{StaticResource ListSecondaryText}"/>
									<TextBlock Grid.Column="3" Text="{Binding Size}" Style="{StaticResource ListSecondaryText}"/>
									<TextBlock Grid.Column="4" Text="{Binding Modified}" Style="{StaticResource ListSecondaryText}"/>
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
					<WrapPanel>
						<Button x:Name="BtnUp" Style="{StaticResource BaseButton}" Click="GoUp" Margin="0,0,8,0"/>
						<Button x:Name="BtnRefresh" Style="{StaticResource AccentButton}" Click="Refresh" Margin="0,0,8,0"/>
						<Button x:Name="BtnImport" Style="{StaticResource BaseButton}" Click="Import" Margin="0,0,8,0"/>
						<Button x:Name="BtnPack" Style="{StaticResource BaseButton}" Click="Pack" Margin="0,0,8,0"/>
						<Button x:Name="BtnDel" Style="{StaticResource DangerButton}" Click="Del"/>
					</WrapPanel>
				</StackPanel>
			</Border>
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock x:Name="LblActions" Style="{StaticResource SectionTitle}"/>
					<Button x:Name="ToggleBtn" Style="{StaticResource BaseButton}" Click="Toggle" HorizontalAlignment="Left" Margin="0,0,0,12"/>
					<TextBlock x:Name="NickDesc" Foreground="{DynamicResource TextPrimary}"/>
					<Button x:Name="BtnNick" Style="{StaticResource AccentButton}" Click="SubmitNick" Margin="0,8,0,0" HorizontalAlignment="Left"/>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</Page>