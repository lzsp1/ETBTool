<Page x:Class="ETBTool.Views.UE4ManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:etb="clr-namespace:ETBTool.Utils"
      Background="Transparent"
      etb:ScrollBubble.Enabled="True">
	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
		<StackPanel>
			<TextBlock Style="{StaticResource PageTitle}" Text="UE4 管理"/>
			<TextBlock Style="{StaticResource MutedText}"
                       Text="管理游戏安装目录文件（支持 Ctrl+点击多选、双击进入文件夹）"
                       Margin="0,-4,0,20"/>

			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock Style="{StaticResource SectionTitle}" Text="游戏安装路径"/>
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBox x:Name="PathBox" IsReadOnly="True" Margin="0,0,8,0"/>
						<Button Grid.Column="1" Content="打开" Style="{StaticResource BaseButton}"
                                Click="OpenRoot" Margin="0,0,8,0"/>
						<Button Grid.Column="2" Content="复制" Style="{StaticResource BaseButton}"
                                Click="CopyRoot"/>
					</Grid>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource Card}">
				<StackPanel>
					<StackPanel Orientation="Horizontal" Margin="0,0,0,12">
						<TextBlock Style="{StaticResource SectionTitle}" Text="目录内容" Margin="0"/>
						<TextBlock x:Name="CurrentDirText" Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
					</StackPanel>

					<Grid Margin="0,0,0,4">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="160"/>
							<ColumnDefinition Width="120"/>
							<ColumnDefinition Width="160"/>
						</Grid.ColumnDefinitions>
						<TextBlock Text="名称" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
						<TextBlock Grid.Column="1" Text="类型" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
						<TextBlock Grid.Column="2" Text="大小" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
						<TextBlock Grid.Column="3" Text="修改时间" FontWeight="SemiBold" Style="{StaticResource ListSecondaryText}"/>
					</Grid>
					<Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,4"/>

					<!-- ★ 多选 -->
					<ListBox x:Name="ItemListBox" Height="300" Margin="0,0,0,12"
                             SelectionMode="Extended"
                             MouseDoubleClick="Item_DblClick"
                             ItemContainerStyle="{StaticResource TableListBoxItem}">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="160"/>
										<ColumnDefinition Width="120"/>
										<ColumnDefinition Width="160"/>
									</Grid.ColumnDefinitions>
									<TextBlock Text="{Binding Name}" Style="{StaticResource ListPrimaryText}"/>
									<TextBlock Grid.Column="1" Text="{Binding Type}" Style="{StaticResource ListSecondaryText}"/>
									<TextBlock Grid.Column="2" Text="{Binding Size}" Style="{StaticResource ListSecondaryText}"/>
									<TextBlock Grid.Column="3" Text="{Binding Modified}" Style="{StaticResource ListSecondaryText}"/>
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>

					<WrapPanel>
						<Button Content="上级目录" Style="{StaticResource BaseButton}" Click="GoUp" Margin="0,0,8,0"/>
						<Button Content="刷新"    Style="{StaticResource AccentButton}" Click="Refresh" Margin="0,0,8,0"/>
						<Button Content="导入文件" Style="{StaticResource BaseButton}" Click="Import" Margin="0,0,8,0"/>
						<Button Content="删除选中" Style="{StaticResource DangerButton}" Click="DelSel" Margin="0,0,8,0"/>
						<Button Content="一键清空" Style="{StaticResource DangerButton}" Click="DelAll"/>
					</WrapPanel>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</Page>