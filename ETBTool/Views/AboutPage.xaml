<Page x:Class="ETBTool.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:etb="clr-namespace:ETBTool.Utils"
      Background="Transparent" etb:ScrollBubble.Enabled="True">
	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
		<StackPanel MaxWidth="680" HorizontalAlignment="Center">
			<TextBlock Text="ETB Tool" FontSize="32" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"/>
			<TextBlock x:Name="VerText" FontSize="14"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center" Margin="0,4,0,24"/>

			<Border Style="{StaticResource Card}" Padding="28,24">
				<StackPanel>
					<TextBlock x:Name="LblDesc" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
					<TextBlock x:Name="AboutDesc" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" FontSize="14" Margin="0,0,0,24"/>

					<TextBlock x:Name="LblFeatures" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
					<TextBlock x:Name="FeatureList" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" FontSize="14" Margin="0,0,0,24"/>

					<TextBlock x:Name="LblLicense" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
					<TextBlock x:Name="LicenseText" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" FontSize="14" Margin="0,0,0,28"/>

					<Button x:Name="BtnConfig" Style="{StaticResource AccentButton}"
                            Click="Config_Click" Margin="0,0,0,8"
                            HorizontalAlignment="Stretch"/>
					<Button x:Name="BtnWebsite" Style="{StaticResource BaseButton}"
                            Click="Web_Click" Margin="0,0,0,8"
                            HorizontalAlignment="Stretch"/>
					<Button x:Name="BtnSource" Style="{StaticResource BaseButton}"
                            Click="Source_Click"
                            HorizontalAlignment="Stretch"/>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</Page>