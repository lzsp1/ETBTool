<Page x:Class="ETBTool.Views.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:etb="clr-namespace:ETBTool.Utils"
      Background="Transparent"
      etb:ScrollBubble.Enabled="True">
	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
		<StackPanel MaxWidth="400" HorizontalAlignment="Center">
			<TextBlock Text="ETB Tool" FontSize="32" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}"
                       HorizontalAlignment="Center"/>
			<TextBlock x:Name="VerText" FontSize="14"
                       Foreground="{DynamicResource TextSecondary}"
                       HorizontalAlignment="Center" Margin="0,4,0,24"/>

			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock Text="简介" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
					<TextBlock Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="逃离后室（Escape the Backrooms）游戏辅助工具"/>

					<TextBlock Text="功能" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
					<TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,4"
                               Text="• 存档管理"/>
					<TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,4"
                               Text="• 崩溃日志查看"/>
					<TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,4"
                               Text="• UE4 资源管理"/>
					<TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,4"
                               Text="• Mod 管理与翻译"/>
					<TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,4"
                               Text="• 游戏路径自动检测"/>
					<TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,4"
                               Text="• 主题切换与自定义"/>
					<TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="• 一键更新检查"/>

					<TextBlock Text="开源协议" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
					<TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,20"
                               Text="本工具基于 MIT 开源协议发布，欢迎二创与分发。"/>

					<!-- 竖排按钮 -->
					<Button Content="打开配置目录" Style="{StaticResource AccentButton}"
                            Click="Config_Click" Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
					<Button Content="官方网站" Style="{StaticResource BaseButton}"
                            Click="Web_Click" Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
					<Button Content="开源仓库" Style="{StaticResource BaseButton}"
                            Click="Source_Click" HorizontalAlignment="Stretch"/>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</Page>