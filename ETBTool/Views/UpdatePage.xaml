<Page x:Class="ETBTool.Views.UpdatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:etb="clr-namespace:ETBTool.Utils"
      Background="Transparent" etb:ScrollBubble.Enabled="True">
	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
		<StackPanel>
			<TextBlock x:Name="PageTitle" Style="{StaticResource PageTitle}"/>

			<!-- 板块1: 当前版本 -->
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock x:Name="LblCurVer" Style="{StaticResource SectionTitle}"/>
					<TextBlock x:Name="CurVer" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
				</StackPanel>
			</Border>

			<!-- 板块2: 检查更新 -->
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock x:Name="LblCheck" Style="{StaticResource SectionTitle}"/>
					<Button x:Name="BtnCheck" Style="{StaticResource AccentButton}"
                            Click="Check_Click" HorizontalAlignment="Left"/>
					<ProgressBar x:Name="Progress" Height="6" Margin="0,12,0,0"
                                 Visibility="Collapsed"
                                 Background="{DynamicResource SurfaceColor}"
                                 Foreground="{DynamicResource AccentColor}"/>
					<TextBlock x:Name="StatusText" Style="{StaticResource MutedText}"
                               Margin="0,8,0,0"/>
					<StackPanel x:Name="UpdatePanel" Visibility="Collapsed"
                                Margin="0,12,0,0">
						<TextBlock x:Name="UpdateText" Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"/>
						<Button x:Name="DLBtn" Style="{StaticResource AccentButton}"
                                Click="DL_Click" Margin="0,12,0,0"
                                HorizontalAlignment="Left"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<!-- 板块3: 更新日志 -->
			<Border Style="{StaticResource Card}">
				<StackPanel>
					<TextBlock x:Name="LblLog" Style="{StaticResource SectionTitle}"/>
					<Button x:Name="BtnChangelog" Style="{StaticResource BaseButton}"
                            Click="OpenLog_Click" HorizontalAlignment="Left"/>
				</StackPanel>
			</Border>
		</StackPanel>
	</ScrollViewer>
</Page>