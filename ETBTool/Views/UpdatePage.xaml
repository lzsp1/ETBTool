<Page x:Class="ETBTool.Views.UpdatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
        <StackPanel MaxWidth="600">
            <TextBlock Style="{StaticResource PageTitle}" Text="  检查更新"/>
            <TextBlock Style="{StaticResource MutedText}" Text="检查是否有新版本可用" Margin="0,-4,0,20"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="当前版本"/>
                    <TextBlock x:Name="CurVer" FontSize="16" Foreground="{DynamicResource TextPrimary}" Text="加载中..."/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="检查状态"/>
                    <ProgressBar x:Name="Progress" Height="6" Margin="0,0,0,12" IsIndeterminate="False" Value="0" Visibility="Collapsed"/>
                    <TextBlock x:Name="StatusText" Text="点击下方按钮检查更新" Foreground="{DynamicResource TextPrimary}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,16"/>
                    <Border x:Name="UpdatePanel" Visibility="Collapsed" Background="{DynamicResource SurfaceColor}" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="更新内容" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="UpdateText" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" FontSize="13" LineHeight="22"/>
                        </StackPanel>
                    </Border>
                    <WrapPanel>
                        <Button x:Name="CheckBtn" Content="检查更新" Style="{StaticResource AccentButton}" Click="Check_Click" Margin="0,0,8,0" Padding="24,10"/>
                        <Button x:Name="DLBtn" Content="前往下载" Style="{StaticResource BaseButton}" Click="DL_Click" Visibility="Collapsed" Padding="24,10"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="更新日志"/>
                    <TextBlock Text="查看最新版本的更新内容和修复记录。" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                    <Button Content="查看更新记录" Style="{StaticResource BaseButton}" Click="OpenLog_Click" Margin="0,12,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>